{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "madhavi-ADF"
        },
        "AzureDataLakeStorage1_accountKey": {
            "type": "secureString",
            "metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
        },
        "AzureDataLakeStorage1_properties_typeProperties_url": {
            "type": "string",
            "defaultValue": "https://storagedatafactorymad.dfs.core.windows.net/"
        },
        "HttpServer1_properties_typeProperties_url": {
            "type": "string",
            "defaultValue": "https://raw.githubusercontent.com"
        },
        "managerTriger_properties_typeProperties_scope": {
            "type": "string",
            "defaultValue": "/subscriptions/a7356cb3-1cdc-447f-8b46-39045fb18094/resourceGroups/RG-ADFMadhavi/providers/Microsoft.Storage/storageAccounts/storagedatafactorymad"
        },
        "ManTrigger_properties_typeProperties_scope": {
            "type": "string",
            "defaultValue": "/subscriptions/a7356cb3-1cdc-447f-8b46-39045fb18094/resourceGroups/RG-ADFMadhavi/providers/Microsoft.Storage/storageAccounts/storagedatafactorymad"
        },
        "containerUri": {
            "type": "string",
            "metadata": "URI to storage account containing linked ARM templates"
        },
        "containerSasToken": {
            "type": "string",
            "metadata": "Sas token to storage account containing linked ARM templates"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "madhavi-ADF_ArmTemplate_0",
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2024-03-01",
            "properties": {
                "mode": "incremental",
                "templateLink": {
                    "uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "factoryName": {
                        "value": "[parameters('factoryName')]"
                    },
                    "AzureDataLakeStorage1_accountKey": {
                        "value": "[parameters('AzureDataLakeStorage1_accountKey')]"
                    },
                    "AzureDataLakeStorage1_properties_typeProperties_url": {
                        "value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
                    },
                    "HttpServer1_properties_typeProperties_url": {
                        "value": "[parameters('HttpServer1_properties_typeProperties_url')]"
                    },
                    "managerTriger_properties_typeProperties_scope": {
                        "value": "[parameters('managerTriger_properties_typeProperties_scope')]"
                    },
                    "ManTrigger_properties_typeProperties_scope": {
                        "value": "[parameters('ManTrigger_properties_typeProperties_scope')]"
                    }
                }
            },
            "dependsOn": []
        }
    ]
}